# ==============================================================
# itemSelector environment variables (example)
# Copy this file to .env and fill in actual values.
# ==============================================================

# --- PostgreSQL ---
POSTGRES_USER=itemselector
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=itemselector
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# DATABASE_URL is built from the values above and injected into api/scheduler
DATABASE_URL=postgresql+psycopg://itemselector:change_me_in_production@postgres:5432/itemselector

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Host port exposure ---
# api + web bind to 127.0.0.1 only; an external reverse proxy (e.g.
# Caddy from another compose project) fronts them with HTTPS + basic
# auth. Override if these ports collide on the host.
API_HOST_PORT=8001
WEB_HOST_PORT=3001

# --- Backend (FastAPI) ---
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info
# Whitelist the subdomain your Caddy serves (+ localhost for dev).
API_CORS_ORIGINS=https://itemselector.mooo.com,http://localhost:3000

# --- Frontend (Next.js) ---
# Browser-visible endpoint. With external Caddy fronting /api/* on the
# subdomain, this should be the public URL (same-origin recommended).
NEXT_PUBLIC_API_BASE_URL=https://itemselector.mooo.com/api
# Server-side (container-to-container) — keep as api:8000
INTERNAL_API_BASE_URL=http://api:8000

# --- Naver Open APIs ---
NAVER_SEARCHAD_API_KEY=your_searchad_api_key
NAVER_SEARCHAD_SECRET_KEY=your_searchad_secret_key
NAVER_SEARCHAD_CUSTOMER_ID=your_customer_id
NAVER_OPENAPI_CLIENT_ID=your_openapi_client_id
NAVER_OPENAPI_CLIENT_SECRET=your_openapi_client_secret

# --- Coupang Partners API ---
COUPANG_PARTNERS_ACCESS_KEY=your_coupang_access_key
COUPANG_PARTNERS_SECRET_KEY=your_coupang_secret_key

# --- Korea Customs Service (관세청) ---
CUSTOMS_API_KEY=your_customs_api_key
# HS codes are imported from a downloaded Excel file (data.go.kr fileData),
# NOT an API. Use: python -m scripts.import_hs_codes --file <path>.xlsx

# --- Korea Exim Bank (exchange rate) ---
EXIM_BANK_API_KEY=your_exim_bank_api_key

# --- YouTube Data API v3 ---
YOUTUBE_API_KEY=your_youtube_api_key

# --- Google Trends (pytrends has no API key) ---
# (intentionally left blank)

# --- Feature flags ---
USE_MOCK_CLIENTS=false
